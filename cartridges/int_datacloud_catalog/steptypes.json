{
    "step-types": {
        "script-module-step": [
            {
                "@type-id": "custom.ExportProductsToDataCloud",
                "@supports-site-context": "true",
                "@supports-organization-context": "false",
                "module": "int_datacloud_catalog/cartridge/scripts/jobs/exportProductsToDataCloud",
                "function": "execute",
                "parameters": {
                    "parameters": [
                        {
                            "@name": "ConnectorName",
                            "@type": "string",
                            "@required": true,
                            "@trim": true,
                            "description": "Data Cloud Ingestion API connector name e.g. MyB2CConnector"
                        },
                        {
                            "@name": "JobConfig",
                            "@type": "string",
                            "@required": "false",
                            "@trim": "true",
                            "description": "Optional JSON config. Defaults: online products only, all site products (no category scope), 800KB batches, Product object, int_datacloud.auth service, 120 poll attempts (~10 min), debug logging off.",
                            "default-value": "{\"onlineOnly\":true,\"inStockOnly\":false,\"catalogId\":\"\",\"categoryId\":\"root\",\"categoryRollup\":true,\"objectName\":\"Product\",\"serviceId\":\"int_datacloud.auth\",\"batchSizeKB\":800,\"maxPollAttempts\":120,\"enableDebugLogging\":false}"
                        }
                    ]
                },
                "status-codes": {
                    "status": [
                        {
                            "@code": "ERROR",
                            "description": "Used when an error occurred during product export or ingestion"
                        },
                        {
                            "@code": "OK",
                            "description": "Used when product export and ingestion completed successfully"
                        }
                    ]
                }
            }
        ]
    }
}
